# Core deployment identity
NODE_ENV=production
TROPTIONS_DEPLOYMENT_ID=deploy-2026-04-25-001
TROPTIONS_RELEASE_CHANNEL=prod

# Control-plane deployment policy
TROPTIONS_CONTROL_PLANE_WRITES_ENABLED=0
TROPTIONS_ALLOW_NON_PROD_CHANNEL_WRITES=0
TROPTIONS_DEPLOYMENT_LOCKDOWN=0

# Auth and operator controls
TROPTIONS_ALLOW_STATIC_TOKEN_AUTH=0
# TROPTIONS_CONTROL_PLANE_TOKEN=replace-me-if-you-explicitly-enable-static-token-auth
TROPTIONS_OPERATOR_IP_ALLOWLIST=
TROPTIONS_ENFORCE_OPERATOR_SECURITY=1
TROPTIONS_SENSITIVE_ACTIONS=

# JWT keyset (preferred)
# TROPTIONS_JWT_KEYS_JSON={"activeKid":"jwt-k1","keys":[{"kid":"jwt-k1","secret":"replace-with-32-plus-char-secret","enabled":true}]}

# Legacy JWT fallback (not preferred)
# TROPTIONS_JWT_SECRET=replace-with-32-plus-char-secret

# Audit export signing keys (preferred)
# TROPTIONS_AUDIT_EXPORT_KEYS_JSON={"activeKid":"audit-k1","keys":[{"kid":"audit-k1","secret":"replace-with-32-plus-char-secret","enabled":true}]}

# Legacy audit fallback
# TROPTIONS_AUDIT_EXPORT_SECRET=replace-with-32-plus-char-secret
# TROPTIONS_AUDIT_EXPORT_KEY_ID=audit-k1

# Request controls
TROPTIONS_RATE_LIMIT_PER_MINUTE=120
TROPTIONS_RATE_LIMIT_WINDOW_SECONDS=60
TROPTIONS_IDEMPOTENCY_TTL_SECONDS=600

# Phase 9 data layer
TROPTIONS_DB_ADAPTER=sqlite
# DATABASE_URL=postgres://user:password@host:5432/troptions

# Phase 9 observability
# TROPTIONS_BASE_URL=https://your-deployment-host
